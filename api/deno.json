{
  "compilerOptions": {
    "checkJs": true,
    "strict": true
  },
  "imports": {},
  "lint": {
    "rules": {
      "include": [],
      "exclude": ["no-unused-vars", "no-empty"]
    }
  },
  "permissions": {
    "default": {
      "env": true,
      "net": true,
      "read": ["./database"],
      "write": ["./database"],
      "import": true
    }
  },
  "tasks": {
    "dev": "deno run -P --no-prompt --watch main.ts",
    "test": "deno test -P --watch"
  }
}
